extends ../layout

block content
  .row.justify-content-center
    .col-md-8
      .card.mt-4
        .card-body
          h3.card-title= post.title
          p.text-muted
            | Por 
            strong= post.User.display_name || post.User.username
            |  · 
            = new Date(post.created_at).toLocaleDateString('es-AR')
          
          if post.description
            p= post.description

          //- Imágenes
          .row.mt-3
            each image in post.Images
              .col-md-6.mb-3
                img.img-fluid.rounded(src=image.file_path alt=post.title)
                if image.license === 'copyright'
                  span.badge.bg-warning.mt-1 © Copyright

          //- Etiquetas
          if post.Tags && post.Tags.length
            .mt-3
              each tag in post.Tags
                span.badge.bg-secondary.me-1 ##{tag.name}

          //- Botones
          .mt-4
            a.btn.btn-outline-dark(href="/") Volver al inicio
            if user && user.id === post.user_id
              a.btn.btn-warning.ms-2(href=`/posts/${post.id}/edit`) Editar