extends ../layout

block content
  .row.justify-content-center
    .col-md-5
      .card.mt-5
        .card-body
          h3.card-title.text-center.mb-4 Crear cuenta
          form(action="/auth/register" method="POST")
            .mb-3
              label.form-label Nombre de usuario
              input.form-control(type="text" name="username" required)
            .mb-3
              label.form-label Email
              input.form-control(type="email" name="email" required)
            .mb-3
              label.form-label Nombre visible
              input.form-control(type="text" name="display_name")
            .mb-3
              label.form-label Contraseña
              input.form-control(type="password" name="password" required)
            button.btn.btn-dark.w-100(type="submit") Registrarse
          p.text-center.mt-3
            | ¿Ya tenés cuenta?
            a(href="/auth/login")  Iniciá sesión