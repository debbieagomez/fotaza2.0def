doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Fotaza 2
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="/") 📷 Fotaza 2
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navMenu")
          span.navbar-toggler-icon
        #navMenu.collapse.navbar-collapse
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href="/") Inicio
            li.nav-item
              a.nav-link(href="/search") Buscar
            if user
              li.nav-item
                a.nav-link(href="/posts/create")
                  i.bi.bi-plus-circle.me-1
                  | Publicar
          ul.navbar-nav.ms-auto
            if user
              li.nav-item
                a.nav-link(href="/profile/" + user.username)
                  i.bi.bi-person-circle.me-1
                  | #{user.display_name || user.username}
              li.nav-item
                form(action="/auth/logout" method="POST")
                  button.btn.btn-outline-light.btn-sm.mt-2(type="submit") Cerrar sesión
            else
              li.nav-item
                a.nav-link(href="/auth/login") Iniciar sesión
              li.nav-item
                a.btn.btn-outline-light.btn-sm.mt-2(href="/auth/register") Registrarse

    .container.mt-3
      if success_msg && success_msg.length
        .alert.alert-success.alert-dismissible.fade.show
          = success_msg
          button.btn-close(type="button" data-bs-dismiss="alert")
      if error_msg && error_msg.length
        .alert.alert-danger.alert-dismissible.fade.show
          = error_msg
          button.btn-close(type="button" data-bs-dismiss="alert")

    main.container.py-4
      block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    block scripts